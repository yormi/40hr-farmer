            var errorEl = document.getElementById('form-error');
            errorEl.classList.add('hidden');
            btn.textContent = 'Submitting...';
            btn.disabled = true;

            var data = JSON.stringify({
              fields: [
                { name: 'firstname', value: document.getElementById('firstname').value },
                { name: 'lastname', value: document.getElementById('lastname').value },
                { name: 'email', value: document.getElementById('email').value }
              ],
              context: {
                pageUri: window.location.href,
                pageName: document.title
              }
            });

            var xhr = new XMLHttpRequest();
            xhr.open('POST', 'https://api.hsforms.com/submissions/v3/integration/submit/5156324/036c50fb-2650-48ba-a1af-eb12a8f1074e');
            xhr.setRequestHeader('Content-Type', 'application/json');
            xhr.onload = function() {
              if (xhr.status === 200) {
                // Track conversion in GA4
                gtag('event', 'waitlist_signup', {
                  event_category: 'conversion',
                  event_label: 'waitlist_form'
                });
                document.getElementById('waitlist-form').classList.add('hidden');
                document.getElementById('form-success').classList.remove('hidden');
              } else {
                errorEl.classList.remove('hidden');
                btn.textContent = 'Join the Program';
                btn.disabled = false;
              }
            };
            xhr.onerror = function() {
              errorEl.classList.remove('hidden');
              btn.textContent = 'Join the Program';
              btn.disabled = false;
            };
            xhr.send(data);
          });
